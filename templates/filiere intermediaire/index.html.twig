<!DOCTYPE html>

<title>Filiere index</title>

{% block body %}
    <h1>Filiere index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Domaine</th>
                <th>Description</th>
                <th>Condition_admission</th>
                <th>Debouches</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for filiere in filieres %}
            <tr>
                <td>{{ filiere.id }}</td>
                <td>{{ filiere.nom }}</td>
                <td>{{ filiere.domaine }}</td>
                <td>{{ filiere.description }}</td>
                <td>{{ filiere.conditionAdmission }}</td>
                <td>{{ filiere.debouches }}</td>
                <td>
                    <a href="{{ path('app_filiere_show', {'id': filiere.id}) }}">show</a>
                    <a href="{{ path('app_filiere_edit', {'id': filiere.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_filiere_new') }}">Create new</a>
{% endblock %}
