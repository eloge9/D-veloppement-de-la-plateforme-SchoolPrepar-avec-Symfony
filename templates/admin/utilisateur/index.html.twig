{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Utilisateurs - SchoolPrepar Admin{% endblock %}

{% block content %}
<div class="container-fluid">

    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            Gestion des Utilisateurs
            {% if current_role %}
                <small class="text-muted">({{ current_role == 'conseiller' ? 'CONSEILLERS' : (current_role == 'eleve' ? 'ÉLÈVES' : 'ADMINISTRATEURS') }})</small>
            {% endif %}
        </h1>
        <a href="{{ path('admin_utilisateur_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Nouvel Utilisateur
        </a>
    </div>

    <!-- Filtres par rôle -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Filtrer par rôle</h6>
        </div>
        <div class="card-body">
            <div class="btn-group" role="group">
                <a href="{{ path('admin_utilisateur_index') }}" class="btn {% if not current_role %}btn-primary{% else %}btn-outline-primary{% endif %}">
                     Tous
                </a>
                <a href="{{ path('admin_utilisateur_by_role', {'role': 'admin'}) }}" class="btn {% if current_role == 'admin' %}btn-danger{% else %}btn-outline-danger{% endif %}">
                     Administrateurs
                </a>
                <a href="{{ path('admin_utilisateur_by_role', {'role': 'conseiller'}) }}" class="btn {% if current_role == 'conseiller' %}btn-warning{% else %}btn-outline-warning{% endif %}">
                     Conseillers
                </a>
                <a href="{{ path('admin_utilisateur_by_role', {'role': 'eleve'}) }}" class="btn {% if current_role == 'eleve' %}btn-info{% else %}btn-outline-info{% endif %}">
                     Élèves
                </a>
            </div>
        </div>
    </div>

    <!-- Tableau des utilisateurs -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                Liste des Utilisateurs
                {% if current_role %}
                    <span class="badge badge-{{ current_role == 'admin' ? 'danger' : (current_role == 'conseiller' ? 'warning' : 'info') }}">
                        {{ utilisateurs|length }} {{ current_role == 'conseiller' ? 'conseiller(s)' : (current_role == 'eleve' ? 'élève(s)' : 'administrateur(s)') }}
                    </span>
                {% endif %}
            </h6>
        </div>
        <div class="card-body">
            {% if utilisateurs is defined and utilisateurs|length > 0 %}
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Date d'inscription</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tfoot>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Date d'inscription</th>
                            <th>Actions</th>
                        </tr>
                    </tfoot>
                    <tbody>
                        {% for utilisateur in utilisateurs %}
                        <tr>
                            <td>{{ utilisateur.id }}</td>
                            <td>{{ utilisateur.nom }}</td>
                            <td>
                                <a href="mailto:{{ utilisateur.email }}" class="text-decoration-none">
                                    {{ utilisateur.email }}
                                </a>
                            </td>
                            <td>
                                <span class="badge badge-{{ utilisateur.role == 'admin' ? 'danger' : (utilisateur.role == 'conseiller' ? 'warning' : 'info') }}">
                                    {{ utilisateur.role == 'conseiller' ? 'CONSEILLER' : (utilisateur.role == 'eleve' ? 'ÉLÈVE' : 'ADMIN') }}
                                </span>
                            </td>
                            <td>{{ utilisateur.dateInscription ? utilisateur.dateInscription|date('d/m/Y H:i') : 'N/A' }}</td>
                            <td>
                                <a href="{{ path('admin_utilisateur_show', {'id': utilisateur.id}) }}" class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('admin_utilisateur_delete', {'id': utilisateur.id}) }}" style="display:inline;" onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                                    <button class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="alert alert-info text-center">
                <h4>Aucun utilisateur trouvé</h4>
                <p>
                    {% if current_role %}
                        Il n'y a actuellement aucun {{ current_role == 'conseiller' ? 'conseiller' : (current_role == 'eleve' ? 'élève' : 'administrateur') }} enregistré dans le système.
                    {% else %}
                        Il n'y a actuellement aucun utilisateur enregistré dans le système.
                    {% endif %}
                </p>
                <a href="{{ path('admin_utilisateur_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Ajouter un utilisateur
                </a>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
<!-- Page level plugins -->
<script src="https://cdn.datatables.net/1.10.20/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.10.20/js/dataTables.bootstrap4.min.js"></script>

<script>
$(document).ready(function() {
    $('#dataTable').DataTable({
        "language": {
            "url": "//cdn.datatables.net/plug-ins/9dcbecd42ad/i18n/French.json"
        },
        "pageLength": 25,
        "responsive": true
    });
});
</script>
{% endblock %}
