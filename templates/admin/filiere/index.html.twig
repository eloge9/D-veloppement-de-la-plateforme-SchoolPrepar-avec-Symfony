{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Filières - SchoolPrepar Admin{% endblock %}

{% block content %}
<div class="container-fluid">

    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Filières</h1>
        <a href="{{ path('admin_filiere_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Nouvelle Filière
        </a>
    </div>

    <!-- DataTales Example -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des Filières</h6>
        </div>
        <div class="card-body">
            {% if filieres is defined and filieres|length > 0 %}
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Domaine</th>
                            <th>Établissement</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tfoot>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Domaine</th>
                            <th>Établissement</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </tfoot>
                    <tbody>
                        {% for filiere in filieres %}
                        <tr>
                            <td>{{ filiere.id }}</td>
                            <td>{{ filiere.nom }}</td>
                            <td>{{ filiere.domaine }}</td>
                            <td>
                                {% if filiere.etablissement %}
                                    <a href="{{ path('admin_etablissement_show', {'id': filiere.etablissement.id}) }}" class="btn btn-sm btn-outline-info">
                                        {{ filiere.etablissement.nom }}
                                    </a>
                                {% else %}
                                    <span class="text-muted">Non spécifié</span>
                                {% endif %}
                            </td>
                            <td>{{ filiere.description|slice(0, 50) ~ '...' }}</td>
                            <td>
                                <a href="{{ path('admin_filiere_show', {'id': filiere.id}) }}" class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_filiere_edit', {'id': filiere.id}) }}" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post"
                                    action="{{ path('admin_filiere_delete', {'id': filiere.id}) }}"
                                    style="display:inline;"
                                    onsubmit="return confirm('Supprimer cette filière ?');">

                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ filiere.id) }}">

                                    <button class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="alert alert-info text-center">
                <h4>Aucune filière trouvée</h4>
                <p>Il n'y a actuellement aucune filière enregistrée dans le système.</p>
                <a href="{{ path('admin_filiere_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Ajouter une filière
                </a>
            </div>
            {% endif %}
        </div>
    </div>

</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirmation de suppression</h5>
                <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                Êtes-vous sûr de vouloir supprimer cette filière ? Cette action est irréversible.
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-dismiss="modal">Annuler</button>
                <button class="btn btn-danger" id="confirmDeleteBtn">Supprimer</button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<!-- Page level plugins -->
<script src="https://cdn.datatables.net/1.10.20/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.10.20/js/dataTables.bootstrap4.min.js"></script>

<script>
$(document).ready(function() {
    $('#dataTable').DataTable({
        "language": {
            "url": "//cdn.datatables.net/plug-ins/9dcbecd42ad/i18n/French.json"
        },
        "pageLength": 25,
        "responsive": true
    });
});

function confirmDelete(id) {
    $('#deleteModal').modal('show');
    $('#confirmDeleteBtn').data('id', id);
}

$('#confirmDeleteBtn').click(function() {
    var id = $(this).data('id');
    window.location.href = '/admin/filiere/delete/' + id;
});
</script>
{% endblock %}