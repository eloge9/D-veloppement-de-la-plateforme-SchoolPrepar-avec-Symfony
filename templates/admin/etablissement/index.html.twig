{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Établissements - SchoolPrepar Admin{% endblock %}

{% block content %}
<div class="container-fluid">

    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Établissements</h1>
        <a href="{{ path('admin_etablissement_new') }}"
            class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Nouvel Établissement
        </a>
    </div>

    <!-- DataTales Example -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des Établissements</h6>
        </div>
        <div class="card-body">
            {% if etablissements is defined and etablissements|length > 0 %}
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Date d'inscription</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tfoot>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Date d'inscription</th>
                            <th>Actions</th>
                        </tr>
                    </tfoot>
                    <tbody>
                        {% for etablissement in etablissements %}
                        <tr>
                            <td>{{ etablissement.id }}</td>
                            <td>{{ etablissement.nom }}</td>
                            <td>
                                <a href="mailto:{{ etablissement.email }}" class="text-decoration-none">
                                    {{ etablissement.email }}
                                </a>
                            </td>
                            <td>
                                <span class="badge badge-secondary">
                                    ÉTABLISSEMENT
                                </span>
                            </td>
                            <td>{{ etablissement.dateInscription ? etablissement.dateInscription|date('d/m/Y H:i') :
                                'N/A' }}</td>
                            <td>
                                <a href="{{ path('admin_etablissement_show', {'id': etablissement.id}) }}"
                                    class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_etablissement_edit', {'id': etablissement.id}) }}"
                                    class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post"
                                    action="{{ path('admin_etablissement_delete', {'id': etablissement.id}) }}"
                                    style="display: inline;">
                                    <input type="hidden" name="_token"
                                        value="{{ csrf_token('delete' ~ etablissement.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet établissement ?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="alert alert-info text-center">
                <h4>Aucun établissement trouvé</h4>
                <p>Il n'y a actuellement aucun établissement enregistré dans le système.</p>
                <a href="{{ path('admin_etablissement_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Ajouter un établissement
                </a>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}