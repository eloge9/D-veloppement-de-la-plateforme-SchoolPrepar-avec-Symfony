{% extends 'admin/base.html.twig' %}

{% block title %}Détails Établissement - SchoolPrepar Admin{% endblock %}

{% block content %}
<div class="container-fluid">

    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Détails de l'Établissement</h1>
        <div>
            <a href="{{ path('admin_etablissement_edit', {'id': etablissement.id}) }}" class="d-none d-sm-inline-block btn btn-sm btn-warning shadow-sm">
                <i class="fas fa-edit fa-sm text-white-50"></i> Modifier
            </a>
            <a href="{{ path('admin_etablissement_index') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
                <i class="fas fa-arrow-left fa-sm text-white-50"></i> Retour à la liste
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Informations de l'établissement</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 150px;">ID</th>
                            <td>{{ etablissement.id }}</td>
                        </tr>
                        <tr>
                            <th>Nom</th>
                            <td>{{ etablissement.nom }}</td>
                        </tr>
                        <tr>
                            <th>Adresse</th>
                            <td>{{ etablissement.addresse|default('Non spécifiée') }}</td>
                        </tr>
                        <tr>
                            <th>Ville</th>
                            <td>{{ etablissement.ville|default('Non spécifiée') }}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 150px;">Contact</th>
                            <td>{{ etablissement.contact|default('Non spécifié') }}</td>
                        </tr>
                        <tr>
                            <th>Site Web</th>
                            <td>
                                {% if etablissement.siteWeb %}
                                    <a href="{{ etablissement.siteWeb }}" target="_blank" class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-external-link-alt"></i> Visiter le site
                                    </a>
                                {% else %}
                                    <span class="text-muted">Non spécifié</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Date de création</th>
                            <td>{{ etablissement.id ? 'ID #' ~ etablissement.id : 'N/A' }}</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
