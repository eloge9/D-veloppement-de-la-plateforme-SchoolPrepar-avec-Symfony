<!DOCTYPE html>

<title>Etablissement index</title>

{% block body %}
    <h1>Etablissement index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Addresse</th>
                <th>Ville</th>
                <th>Contact</th>
                <th>Site_web</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for etablissement in etablissements %}
            <tr>
                <td>{{ etablissement.id }}</td>
                <td>{{ etablissement.nom }}</td>
                <td>{{ etablissement.addresse }}</td>
                <td>{{ etablissement.ville }}</td>
                <td>{{ etablissement.contact }}</td>
                <td>{{ etablissement.siteWeb }}</td>
                <td>
                    <a href="{{ path('app_etablissement_show', {'id': etablissement.id}) }}">show</a>
                    <a href="{{ path('app_etablissement_edit', {'id': etablissement.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_etablissement_new') }}">Create new</a>
{% endblock %}
