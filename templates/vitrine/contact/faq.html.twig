{% extends 'vitrine/base.html.twig' %}

{% block title %}FAQ - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">FAQ</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_contact') }}">Contact</a></span> <span>FAQ</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Questions fréquentes</h2>
                <p>Trouvez les réponses à vos questions</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-8">
                <div class="accordion">
                    <div class="card">
                        <div class="card-header">
                            <h5>Comment fonctionne le test d'orientation ?</h5>
                        </div>
                        <div class="card-body">
                            <p>Le test d'orientation évalue vos aptitudes et vos centres d'intérêt...</p>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header">
                            <h5>Les services sont-ils gratuits ?</h5>
                        </div>
                        <div class="card-body">
                            <p>La plupart de nos services sont gratuits pour les élèves...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
