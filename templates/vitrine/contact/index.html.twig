{% extends 'vitrine/base.html.twig' %}

{% block title %}Contact - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Contact</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span>Contact</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Contactez-nous</h2>
                <p>Nous sommes à votre disposition</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_contact_nous') }}">Qui sommes-nous</a></h3>
                    <p>Découvrez notre équipe</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_contact_formulaire') }}">Formulaire</a></h3>
                    <p>Envoyez-nous un message</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_contact_rdv') }}">Rendez-vous</a></h3>
                    <p>Prendre rendez-vous</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
