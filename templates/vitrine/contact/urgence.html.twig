{% extends 'vitrine/base.html.twig' %}

{% block title %}Contact d'urgence - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Contact d'urgence</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_contact') }}">Contact</a></span> <span>Urgence</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Besoin d'aide urgente ?</h2>
                <p>Nous sommes disponibles pour vous aider</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-danger">
                    <h4>Numéro d'urgence</h4>
                    <p>Téléphone : 01 23 45 67 89</p>
                    <p>Email : urgence@schoolprepar.fr</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
