{% extends 'vitrine/base.html.twig' %}

{% block title %}Ressources - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Ressources</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span>Ressources</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Nos ressources</h2>
                <p>Articles, guides et documents pour vous aider</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_blog') }}">Blog</a></h3>
                    <p>Articles d'orientation</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_guides') }}">Guides</a></h3>
                    <p>Guides pratiques</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_forum') }}">Forum</a></h3>
                    <p>Discussions</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_videos') }}">Vidéos</a></h3>
                    <p>Vidéos tutorielles</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
