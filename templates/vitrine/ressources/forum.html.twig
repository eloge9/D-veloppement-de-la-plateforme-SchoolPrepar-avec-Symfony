{% extends 'vitrine/base.html.twig' %}

{% block title %}Forum - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Forum</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_ressources') }}">Ressources</a></span> <span>Forum</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Forum de discussion</h2>
                <p>Échangez avec la communauté</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_forum_categorie', {'categorie': 'orientation'}) }}">Orientation</a></h3>
                    <p>Discussions sur l'orientation</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_forum_categorie', {'categorie': 'metiers'}) }}">Métiers</a></h3>
                    <p>Découvrez les métiers</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_ressources_forum_categorie', {'categorie': 'etudes'}) }}">Études</a></h3>
                    <p>Parcours d'études</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
