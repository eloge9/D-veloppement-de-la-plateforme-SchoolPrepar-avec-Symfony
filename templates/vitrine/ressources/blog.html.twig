{% extends 'vitrine/base.html.twig' %}

{% block title %}Blog - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Blog</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_ressources') }}">Ressources</a></span> <span>Blog</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Articles d'orientation</h2>
                <p>Découvrez nos derniers articles</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="blog-entry ftco-animate">
                    <h3><a href="{{ path('app_ressources_blog_show', {'slug': 'orientation-scolaire'}) }}">Comment choisir son orientation</a></h3>
                    <p>Découvrez nos conseils pour bien choisir...</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
