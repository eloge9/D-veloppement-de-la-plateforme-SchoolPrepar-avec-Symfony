{% extends 'vitrine/base.html.twig' %}

{% block title %}Téléchargement - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Téléchargement</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_ressources') }}">Ressources</a></span> <span><a href="{{ path('app_ressources_documents') }}">Documents</a></span> <span>Téléchargement</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Téléchargement du document</h2>
                <p>Document ID: {{ documentId }}</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-info">
                    <h4>Téléchargement en cours...</h4>
                    <p>Le document {{ documentId }} est prêt à être téléchargé.</p>
                    <a href="#" class="btn btn-primary">Télécharger maintenant</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
