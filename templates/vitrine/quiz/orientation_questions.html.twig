{% extends 'vitrine/base.html.twig' %}

{% block title %}Question {{ step }} - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Question {{ step }}</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_quiz') }}">Tests</a></span> <span><a href="{{ path('app_quiz_orientation') }}">Orientation</a></span> <span>Question {{ step }}</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Question {{ step }}</h2>
                <p>Progression: {{ step }}/10</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-8">
                <form method="post" action="{{ path('app_quiz_orientation_result') }}">
                    <div class="form-group">
                        <label for="question">Quelle est votre matière préférée ?</label>
                        <select name="answer" class="form-control">
                            <option value="">Choisissez...</option>
                            <option value="maths">Mathématiques</option>
                            <option value="sciences">Sciences</option>
                            <option value="lettres">Lettres</option>
                            <option value="arts">Arts</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Suivant</button>
                </form>
            </div>
        </div>
    </div>
</section>
{% endblock %}
