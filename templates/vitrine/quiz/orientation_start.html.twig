{% extends 'vitrine/base.html.twig' %}

{% block title %}Commencer le test - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Commencer le test</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_quiz') }}">Tests</a></span> <span><a href="{{ path('app_quiz_orientation') }}">Orientation</a></span> <span>Démarrage</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Prêt à commencer ?</h2>
                <p>Le test prend environ 15 minutes</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 text-center">
                <a href="{{ path('app_quiz_orientation_questions', {'step': 1}) }}" class="btn btn-primary btn-lg">Commencer</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
