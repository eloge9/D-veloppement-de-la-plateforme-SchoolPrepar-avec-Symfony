{% extends 'vitrine/base.html.twig' %}

{% block title %}Accueil - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Bienvenue sur SchoolPrepar</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Découvrez votre orientation</h2>
                <p>Plateforme d'orientation scolaire et professionnelle</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <div class="img" style="background-image: url(images/services-1.jpg);"></div>
                    <div class="text">
                        <h2>Tests d'orientation</h2>
                        <p>Découvrez vos aptitudes et vos centres d'intérêt</p>
                        <a href="{{ path('app_quiz_orientation') }}" class="btn-custom">Commencer</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <div class="img" style="background-image: url(images/services-2.jpg);"></div>
                    <div class="text">
                        <h2>Filières et Établissements</h2>
                        <p>Explorez les différentes possibilités</p>
                        <a href="{{ path('app_filieres') }}" class="btn-custom">Explorer</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <div class="img" style="background-image: url(images/services-3.jpg);"></div>
                    <div class="text">
                        <h2>Conseillers d'orientation</h2>
                        <p>Accompagnement personnalisé</p>
                        <a href="{{ path('app_conseillers') }}" class="btn-custom">Rencontrer</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
