{% extends 'vitrine/base.html.twig' %}

{% block title %}Orientation - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Orientation</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span>Orientation</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Trouvez votre voie</h2>
                <p>Explorez les différentes options d'orientation</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_filieres') }}">Filières</a></h3>
                    <p>Découvrez toutes les filières disponibles</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_etablissements') }}">Établissements</a></h3>
                    <p>Explorez les établissements et leurs offres</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
