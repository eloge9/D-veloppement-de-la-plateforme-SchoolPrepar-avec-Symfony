{% extends 'vitrine/base.html.twig' %}

{% block title %}{{ slug }} - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">{{ slug }}</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_conseillers') }}">Conseillers</a></span> <span>{{ slug }}</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row">
            <div class="col-md-8">
                <h2>{{ slug }}</h2>
                <p>Profil du conseiller...</p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
