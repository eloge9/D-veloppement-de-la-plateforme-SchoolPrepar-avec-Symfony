{% extends 'vitrine/base.html.twig' %}

{% block title %}Événements - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Événements</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span>Événements</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Nos événements</h2>
                <p>Participez à nos événements d'orientation</p>
            </div>
        </div>
        <div class="row">
            {% for evenement in evenements %}
            <div class="col-md-4">
                <div class="services-wrap ftco-animate">
                    <h3><a href="{{ path('app_evenement_show', {'id': evenement.id}) }}">{{ evenement.titre }}</a></h3>
                    <p>{{ evenement.date|date('d/m/Y') }} - {{ evenement.lieu }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
