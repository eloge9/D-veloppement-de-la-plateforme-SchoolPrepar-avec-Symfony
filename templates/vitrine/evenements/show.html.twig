{% extends 'vitrine/base.html.twig' %}

{% block title %}{{ evenement.titre }} - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">{{ evenement.titre }}</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_evenements') }}">Événements</a></span> <span>{{ evenement.titre }}</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row">
            <div class="col-md-8">
                <h2>{{ evenement.titre }}</h2>
                <p><strong>Date:</strong> {{ evenement.date|date('d/m/Y H:i') }}</p>
                <p><strong>Lieu:</strong> {{ evenement.lieu }}</p>
                <p>{{ evenement.description }}</p>
                
                {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_evenement_inscription', {'id': evenement.id}) }}" class="btn btn-primary">S'inscrire</a>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
