{% extends 'vitrine/base.html.twig' %}

{% block title %}Inscription événement - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Inscription</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_evenements') }}">Événements</a></span> <span><a href="{{ path('app_evenement_show', {'id': evenement.id}) }}">{{ evenement.titre }}</a></span> <span>Inscription</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Inscription à {{ evenement.titre }}</h2>
                <p>Confirmez votre participation</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-8">
                <form method="post" action="{{ path('app_evenement_inscription_submit', {'id': evenement.id}) }}">
                    <div class="form-group">
                        <label>Nom complet</label>
                        <input type="text" name="nom" class="form-control" value="{{ app.user.nom }}" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" class="form-control" value="{{ app.user.email }}" required>
                    </div>
                    <div class="form-group">
                        <label>Téléphone</label>
                        <input type="tel" name="telephone" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-primary">Confirmer l'inscription</button>
                </form>
            </div>
        </div>
    </div>
</section>
{% endblock %}
