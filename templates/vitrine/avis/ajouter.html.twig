{% extends 'vitrine/base.html.twig' %}

{% block title %}Ajouter un avis - SchoolPrepar{% endblock %}

{% block body %}
<div class="hero-wrap" style="background-image: url('images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-center justify-content-center" data-scrollax-index="0">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Ajouter un avis</h1>
                <p class="breadcrumbs"><span class="mr-2"><a href="{{ path('app_home') }}">Accueil</a></span> <span><a href="{{ path('app_avis') }}">Avis</a></span> <span>Ajouter</span></p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <h2 class="mb-4">Partagez votre expérience</h2>
                <p>Aidez les autres avec votre témoignage</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-8">
                <form method="post" action="{{ path('app_avis_ajouter_submit') }}">
                    <div class="form-group">
                        <label for="titre">Titre</label>
                        <input type="text" name="titre" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="contenu">Votre avis</label>
                        <textarea name="contenu" class="form-control" rows="5" required></textarea>
                    </div>
                    <div class="form-group">
                        <label for="note">Note</label>
                        <select name="note" class="form-control">
                            <option value="5">5 étoiles</option>
                            <option value="4">4 étoiles</option>
                            <option value="3">3 étoiles</option>
                            <option value="2">2 étoiles</option>
                            <option value="1">1 étoile</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Envoyer mon avis</button>
                </form>
            </div>
        </div>
    </div>
</section>
{% endblock %}
