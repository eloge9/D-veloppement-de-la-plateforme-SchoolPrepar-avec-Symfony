{% extends 'vitrine/base.html.twig' %}

{% block title %}Tests d'Orientation - SchoolPrepar{% endblock %}

{% block content %}
<!-- Hero Section -->
<div class="hero-slide owl-carousel site-blocks-cover">
    <div class="intro-section" style="background-image: url('{{ asset('assets/images/hero_2.jpg') }}');">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12 mx-auto text-center" data-aos="fade-up">
                    <h1 class="display-4 font-weight-bold text-white mb-4">Tests d'Orientation</h1>
                    <h2 class="h3 text-white mb-4">Découvrez Votre Voie</h2>
                    <p class="lead text-white mb-5">Nos tests scientifiques vous aident à identifier les filières qui correspondent 
                        véritablement à votre personnalité, vos intérêts et vos compétences</p>
                    <div class="hero-buttons">
                        <a href="#types-tests" class="btn btn-primary btn-lg px-5 py-3 rounded-0 mr-3">
                            <i class="icon-compass mr-2"></i>Commencer un test
                        </a>
                        <a href="{{ path('app_vitrine_home') }}" class="btn btn-outline-light btn-lg px-5 py-3 rounded-0">
                            <i class="icon-home mr-2"></i>Retour à l'accueil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section Importance des Tests -->
<div class="site-section">
    <div class="container">
        <div class="row mb-5 justify-content-center text-center">
            <div class="col-lg-8 mb-5">
                <h2 class="section-title-underline mb-3">
                    <span>Pourquoi des Tests d'Orientation ?</span>
                </h2>
                <p class="lead">Une décision éclairée est la clé d'un parcours académique réussi</p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="feature-1 border text-center h-100">
                    <div class="icon-wrapper bg-primary mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="flaticon-search text-white" style="font-size: 1.5rem;"></span>
                    </div>
                    <div class="feature-1-content">
                        <h3 class="mb-3">Auto-évaluation</h3>
                        <p>Comprenez vos forces, faiblesses et centres d'intérêt grâce à une analyse approfondie de votre personnalité</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="feature-1 border text-center h-100">
                    <div class="icon-wrapper bg-success mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="flaticon-target text-white" style="font-size: 1.5rem;"></span>
                    </div>
                    <div class="feature-1-content">
                        <h3 class="mb-3">Orientation Précise</h3>
                        <p>Identifiez les filières et métiers qui correspondent le mieux à votre profil unique</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="feature-1 border text-center h-100">
                    <div class="icon-wrapper bg-info mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="flaticon-confidence text-white" style="font-size: 1.5rem;"></span>
                    </div>
                    <div class="feature-1-content">
                        <h3 class="mb-3">Confiance en Soi</h3>
                        <p>Prenez votre décision avec confiance grâce à des recommandations basées sur des données objectives</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section Types de Tests -->
<div id="types-tests" class="site-section bg-light">
    <div class="container">
        <div class="row mb-5 justify-content-center text-center">
            <div class="col-lg-8 mb-5">
                <h2 class="section-title-underline mb-3">
                    <span>Nos Tests d'Orientation</span>
                </h2>
                <p class="lead">Choisissez le test qui correspond à votre besoin actuel</p>
            </div>
        </div>
        <div class="row">
            <!-- Test de Personnalité -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-3"
                                style="width: 80px; height: 80px; display: flex; align-items: center; justify-content: center;">
                                <span class="flaticon-user text-white" style="font-size: 2rem;"></span>
                            </div>
                            <h4 class="card-title">Test de Personnalité</h4>
                        </div>
                        <p class="card-text text-muted mb-4">
                            Découvrez votre type de personnalité et comment elle influence vos choix professionnels. 
                            Basé sur le modèle MBTI adapté au contexte académique français.
                        </p>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>30 questions</li>
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>15 minutes</li>
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>Résultats immédiats</li>
                        </ul>
                        <div class="text-center">
                            <button class="btn btn-primary btn-lg px-4 py-2 rounded-0 w-100" onclick="startTest('personality')">
                                <i class="icon-play mr-2"></i>Commencer le test
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quiz d'Intérêts -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <div class="icon-wrapper bg-success rounded-circle mx-auto mb-3"
                                style="width: 80px; height: 80px; display: flex; align-items: center; justify-content: center;">
                                <span class="flaticon-heart text-white" style="font-size: 2rem;"></span>
                            </div>
                            <h4 class="card-title">Quiz d'Intérêts Professionnels</h4>
                        </div>
                        <p class="card-text text-muted mb-4">
                            Identifiez vos domaines d'intérêt et les métiers qui vous passionnent. 
                            Explorez les filières correspondant à vos centres d'intérêt.
                        </p>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>45 questions</li>
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>20 minutes</li>
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>Filières recommandées</li>
                        </ul>
                        <div class="text-center">
                            <button class="btn btn-success btn-lg px-4 py-2 rounded-0 w-100" onclick="startTest('interests')">
                                <i class="icon-play mr-2"></i>Commencer le quiz
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Test de Compétences -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <div class="icon-wrapper bg-info rounded-circle mx-auto mb-3"
                                style="width: 80px; height: 80px; display: flex; align-items: center; justify-content: center;">
                                <span class="flaticon-medal text-white" style="font-size: 2rem;"></span>
                            </div>
                            <h4 class="card-title">Test de Compétences</h4>
                        </div>
                        <p class="card-text text-muted mb-4">
                            Évaluez vos compétences clés et identifiez les domaines où vous excellez. 
                            Déterminez les filières qui valorisent vos talents naturels.
                        </p>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>40 questions</li>
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>25 minutes</li>
                            <li class="mb-2"><i class="icon-check text-success mr-2"></i>Bilan de compétences</li>
                        </ul>
                        <div class="text-center">
                            <button class="btn btn-info btn-lg px-4 py-2 rounded-0 w-100" onclick="startTest('skills')">
                                <i class="icon-play mr-2"></i>Commencer le test
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section Comment ça Marche -->
<div class="site-section">
    <div class="container">
        <div class="row mb-5 justify-content-center text-center">
            <div class="col-lg-8 mb-5">
                <h2 class="section-title-underline mb-3">
                    <span>Comment Ça Marche ?</span>
                </h2>
                <p class="lead">En 4 étapes simples vers votre orientation idéale</p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="text-white font-weight-bold" style="font-size: 1.5rem;">1</span>
                    </div>
                    <h4 class="mb-3">Choisissez votre test</h4>
                    <p>Sélectionnez le test qui correspond le mieux à vos besoins actuels</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="icon-wrapper bg-success rounded-circle mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="text-white font-weight-bold" style="font-size: 1.5rem;">2</span>
                    </div>
                    <h4 class="mb-3">Répondez aux questions</h4>
                    <p>Soyez honnête et spontané dans vos réponses pour des résultats pertinents</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="icon-wrapper bg-info rounded-circle mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="text-white font-weight-bold" style="font-size: 1.5rem;">3</span>
                    </div>
                    <h4 class="mb-3">Recevez vos résultats</h4>
                    <p>Obtenez une analyse détaillée de votre profil immédiatement</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="icon-wrapper bg-warning rounded-circle mx-auto mb-3"
                        style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <span class="text-white font-weight-bold" style="font-size: 1.5rem;">4</span>
                    </div>
                    <h4 class="mb-3">Explorez les filières</h4>
                    <p>Découvrez les filières recommandées et contactez nos conseillers</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section Appel à l'Action -->
<div class="site-section ftco-subscribe-1" style="background-image: url('{{ asset('assets/images/bg_2.jpg') }}');">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h2 class="text-white mb-3">Prêt à Découvrir Votre Voie ?</h2>
                <p class="text-white mb-4">Rejoignez des milliers d'étudiants qui ont trouvé leur orientation grâce à nos tests</p>
                <div class="d-flex flex-wrap gap-3">
                    {% if app.user %}
                    <a href="{{ path('app_system_eleve') }}" class="btn btn-light btn-lg px-4 py-3 rounded-0">
                        <i class="icon-user mr-2"></i>Accéder à mon espace
                    </a>
                    {% else %}
                    <a href="{{ path('app_register') }}" class="btn btn-light btn-lg px-4 py-3 rounded-0">
                        <i class="icon-user-plus mr-2"></i>S'inscrire pour commencer
                    </a>
                    {% endif %}
                    <a href="#types-tests" class="btn btn-outline-light btn-lg px-4 py-3 rounded-0">
                        <i class="icon-compass mr-2"></i>Voir les tests
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function startTest(testType) {
    {% if app.user %}
    alert('Test ' + testType + ' - Cette fonctionnalité sera bientôt disponible !');
    {% else %}
    if (confirm('Pour sauvegarder vos résultats et accéder à un suivi personnalisé, créez un compte gratuit.')) {
        window.location.href = '{{ path('app_register') }}';
    } else {
        alert('Test ' + testType + ' - Cette fonctionnalité sera bientôt disponible !');
    }
    {% endif %}
}
</script>

{% endblock %}
