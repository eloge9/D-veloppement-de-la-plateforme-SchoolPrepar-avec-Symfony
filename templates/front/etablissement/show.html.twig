{% extends 'front/base.html.twig' %}

{% block title %}{{ etablissement.nom }} - SchoolPrepar{% endblock %}

{% block content %}
<div class="site-section ftco-subscribe-1 site-blocks-cover pb-4"
    style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <h2 class="mb-0">{{ etablissement.nom }}</h2>
                <p>Découvrez cet établissement d'excellence</p>
            </div>
        </div>
    </div>
</div>

<div class="custom-breadcrumns border-bottom">
    <div class="container">
        <a href="{{ path('app_home') }}">Home</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <a href="{{ path('app_etablissements') }}">Établissements</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <span class="current">{{ etablissement.nom }}</span>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                {% if etablissement.image %}
                <div class="mb-5">
                    <img src="{{ asset('uploads/etablissements/' ~ etablissement.image) }}"
                        alt="{{ etablissement.nom }}" class="img-fluid rounded">
                </div>
                {% endif %}

                <div class="mb-5">
                    <h3 class="mb-4">Présentation de l'établissement</h3>
                    <p>{{ etablissement.nom }} est un établissement dédié à l'excellence académique et professionnelle.
                    </p>
                </div>

                <div class="mb-5">
                    <h3 class="mb-4">Informations de contact</h3>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><strong>Adresse:</strong> {{ etablissement.addresse }}</li>
                                <li><strong>Ville:</strong> {{ etablissement.ville|default('Non spécifiée') }}</li>
                                <li><strong>Contact:</strong> {{ etablissement.contact }}</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                {% if etablissement.siteWeb %}
                                <li><strong>Site web:</strong> <a href="{{ etablissement.siteWeb }}" target="_blank">{{
                                        etablissement.siteWeb }}</a></li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>
                </div>

                {% if etablissement.filieres|length > 0 %}
                <div class="mb-5">
                    <h3 class="mb-4">Filières proposées</h3>
                    <div class="row">
                        {% for filiere in etablissement.filieres %}
                        <div class="col-lg-6 mb-4">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">{{ filiere.nom }}</h5>
                                    <p class="card-text">
                                        <small class="text-muted">Domaine: {{ filiere.domaine|default('Non spécifié')
                                            }}</small>
                                    </p>
                                    {% if filiere.description %}
                                    <p class="card-text">{{ filiere.description|slice(0, 100) }}...</p>
                                    {% endif %}
                                    <a href="{{ path('app_filiere_show', {'id': filiere.id}) }}"
                                        class="btn btn-primary btn-sm">Voir la filière</a>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>

            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Actions rapides</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="#" class="btn btn-outline-primary">
                                <i class="icon-envelope"></i> Demander des informations
                            </a>
                            {% if etablissement.siteWeb %}
                            <a href="{{ etablissement.siteWeb }}" target="_blank" class="btn btn-outline-success">
                                <i class="icon-globe"></i> Visiter le site web
                            </a>
                            {% endif %}
                            <button class="btn btn-outline-secondary">
                                <i class="icon-heart"></i> Ajouter aux favoris
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Partager cet établissement</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-around">
                            <a href="#" class="text-primary">
                                <i class="icon-facebook fa-2x"></i>
                            </a>
                            <a href="#" class="text-info">
                                <i class="icon-twitter fa-2x"></i>
                            </a>
                            <a href="#" class="text-primary">
                                <i class="icon-linkedin fa-2x"></i>
                            </a>
                            <a href="#" class="text-success">
                                <i class="icon-whatsapp fa-2x"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="site-section ftco-subscribe-1" style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h2>Des questions sur cet établissement ?</h2>
                <p>Notre équipe d'orientation est là pour vous aider à faire le bon choix.</p>
            </div>
            <div class="col-lg-5">
                <a href="#" class="btn btn-primary rounded py-3 px-4 btn-block">Contacter un conseiller</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}