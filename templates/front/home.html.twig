{% extends 'front/base.html.twig' %}

{% block title %}Accueil - SchoolPrepar{% endblock %}


{% block content %}
<div class="hero-slide owl-carousel site-blocks-cover">
    <div class="intro-section" style="background-image: url('{{ asset('assets/images/hero_1.jpg') }}');">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12 mx-auto text-center" data-aos="fade-up">
                    <h1>SchoolPrepar - Votre Orientation Réussie</h1>
                    <p class="lead text-white mt-3">Trouvez votre voie avec l'accompagnement personnalisé des meilleurs
                        conseillers d'orientation</p>
                </div>
            </div>
        </div>
    </div>

    <div class="intro-section" style="background-image: url('{{ asset('assets/images/hero_1.jpg') }}');">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12 mx-auto text-center" data-aos="fade-up">
                    <h1>Découvrez Votre Future Carrière</h1>
                    <p class="lead text-white mt-3">Explorez les filières, les établissements et construisez votre
                        projet professionnel avec confiance</p>
                </div>
            </div>
        </div>
    </div>
</div>


<div></div>

<div class="site-section">
    <div class="container">
        <div class="row mb-5 justify-content-center text-center">
            <div class="col-lg-4 mb-5">
                <h2 class="section-title-underline mb-5">
                    <span>Nos Services d'Orientation</span>
                </h2>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">

                <div class="feature-1 border">
                    <div class="icon-wrapper bg-primary">
                        <span class="flaticon-mortarboard text-white"></span>
                    </div>
                    <div class="feature-1-content">
                        <h2>Orientation Personnalisée</h2>
                        <p>Un accompagnement sur mesure avec nos conseillers d'orientation experts pour trouver la
                            filière qui vous correspond</p>
                        <p><a href="#" class="btn btn-primary px-4 rounded-0">Découvrir</a></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
                <div class="feature-1 border">
                    <div class="icon-wrapper bg-primary">
                        <span class="flaticon-school-material text-white"></span>
                    </div>
                    <div class="feature-1-content">
                        <h2>Tests d'Orientation</h2>
                        <p>Évaluez vos compétences et vos centres d'intérêt avec nos tests psychotechniques validés par
                            des professionnels</p>
                        <p><a href="#" class="btn btn-primary px-4 rounded-0">Commencer</a></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
                <div class="feature-1 border">
                    <div class="icon-wrapper bg-primary">
                        <span class="flaticon-library text-white"></span>
                    </div>
                    <div class="feature-1-content">
                        <h2>Mentorat Éducatif</h2>
                        <p>Bénéficiez de l'expérience de professionnels et d'étudiants qui partagent leur parcours et
                            leurs conseils</p>
                        <p><a href="#" class="btn btn-primary px-4 rounded-0">En savoir plus</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="site-section">
    <div class="container">


        <div class="row mb-5 justify-content-center text-center">
            <div class="col-lg-6 mb-5">
                <h2 class="section-title-underline mb-3">
                    <span>Filières Populaires</span>
                </h2>
                <p>Découvrez les filières les plus recherchées par nos étudiants et trouvez celle qui correspond à vos
                    aspirations</p>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="owl-slide-3 owl-carousel">
                    {% for filiere in filieres %}
                    <div class="course-1-item">
                        <figure class="thumnail">
                            <a href="{{ path('app_filiere_show', {'id': filiere.id}) }}">
                                <img src="{{ asset('assets/images/course_' ~ random(1, 6) ~ '.jpg') }}"
                                    alt="{{ filiere.nom }}" class="img-fluid">
                            </a>
                            <div class="category">
                                <h3>{{ filiere.nom }}</h3>
                            </div>
                        </figure>
                        <div class="course-1-content pb-4">
                            <h2>{{ filiere.description }}</h2>
                            <div class="rating text-center mb-3">
                                <span class="icon-star2 text-warning"></span>
                                <span class="icon-star2 text-warning"></span>
                                <span class="icon-star2 text-warning"></span>
                                <span class="icon-star2 text-warning"></span>
                                <span class="icon-star2 text-warning"></span>
                            </div>
                            <p class="desc mb-4">{{ filiere.description|slice(0, 100) }}...</p>
                            <p><a href="{{ path('app_filiere_show', {'id': filiere.id}) }}"
                                    class="btn btn-primary rounded-0 px-4">Voir la filière</a></p>
                        </div>
                    </div>
                    {% else %}
                    <p>Aucune filière disponible pour le moment.</p>
                    {% endfor %}
                </div>

            </div>
        </div>



    </div>
</div>




<div class="section-bg style-1" style="background-image: url('{{ asset('assets/images/about_1.jpg') }}');">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <h2 class="section-title-underline style-2">
                    <span>À Propos de SchoolPrepar</span>
                </h2>
            </div>
            <div class="col-lg-8">
                <p class="lead">SchoolPrepar est la plateforme leader de l'orientation scolaire et professionnelle en
                    France, accompagnant chaque année des milliers d'étudiants vers leur voie de réussite.</p>
                <p>Née de la conviction que chaque jeune mérite un accompagnement personnalisé pour faire les bons choix
                    d'orientation, SchoolPrepar met en relation les étudiants avec des conseillers d'orientation
                    expérimentés, des mentors professionnels et des ressources éducatives de qualité. Notre approche
                    innovante combine technologies modernes et expertise humaine pour offrir une expérience unique.</p>
                <p>Grâce à notre réseau de partenaires éducatifs et professionnels, nous proposons un accès direct aux
                    informations sur les filières, les établissements et les débouchés professionnels. Notre mission :
                    vous donner les clés pour construire votre avenir avec confiance et sérénité.</p>
                <p><a href="#">En savoir plus sur notre mission</a></p>
            </div>
        </div>
    </div>
</div>

