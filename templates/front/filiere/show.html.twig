{% extends 'front/base.html.twig' %}

{% block title %}{{ filiere.nom }} - SchoolPrepar{% endblock %}

{% block content %}
<div class="site-section ftco-subscribe-1 site-blocks-cover pb-4" style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <h2 class="mb-0">{{ filiere.nom }}</h2>
                <p>{{ filiere.description|slice(0, 100) }}...</p>
            </div>
        </div>
    </div>
</div> 

<div class="custom-breadcrumns border-bottom">
    <div class="container">
        <a href="{{ path('app_home') }}">Home</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <a href="{{ path('app_filieres') }}">Filieres</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <span class="current">{{ filiere.nom }}</span>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="mb-5">
                    <h3 class="mb-4">Description de la filière</h3>
                    <p>{{ filiere.description }}</p>
                </div>

                <div class="mb-5">
                    <h3 class="mb-4">Établissements proposant cette filière</h3>
                    {% if filiere.etablissements is defined and filiere.etablissements|length > 0 %}
                        <div class="row">
                            {% for etablissement in filiere.etablissements %}
                            <div class="col-lg-6 mb-4">
                                <div class="card">
                                    <div class="card-body">
                                        <h5 class="card-title">{{ etablissement.nom }}</h5>
                                        <p class="card-text">{{ etablissement.adresse }}</p>
                                        <p class="card-text">
                                            <small class="text-muted">
                                                <i class="icon-phone2"></i> {{ etablissement.telephone }}
                                            </small>
                                        </p>
                                        <a href="{{ path('app_etablissement_show', {'id': etablissement.id}) }}" class="btn btn-primary btn-sm">Voir l'établissement</a>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="alert alert-info">
                            <p>Aucun établissement ne propose actuellement cette filière.</p>
                        </div>
                    {% endif %}
                </div>

                <div class="mb-5">
                    <h3 class="mb-4">Informations complémentaires</h3>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><strong>Durée des études:</strong> {{ filiere.duree|default('Non spécifiée') }}</li>
                                <li><strong>Niveau requis:</strong> {{ filiere.niveau|default('Non spécifié') }}</li>
                                <li><strong>Diplôme préparé:</strong> {{ filiere.diplome|default('Non spécifié') }}</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><strong>Capacité d'accueil:</strong> {{ filiere.capacite|default('Non spécifiée') }}</li>
                                <li><strong>Statut:</strong> 
                                    {% if filiere.active %}
                                        <span class="badge badge-success">Actif</span>
                                    {% else %}
                                        <span class="badge badge-secondary">Inactif</span>
                                    {% endif %}
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Actions rapides</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="{{ path('app_contact') }}" class="btn btn-outline-primary">
                                <i class="icon-envelope"></i> Demander des informations
                            </a>
                            <a href="{{ path('app_admissions') }}" class="btn btn-outline-success">
                                <i class="icon-users"></i> S'inscrire
                            </a>
                            <button class="btn btn-outline-secondary">
                                <i class="icon-heart"></i> Ajouter aux favoris
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Partager cette filière</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-around">
                            <a href="#" class="text-primary">
                                <i class="icon-facebook fa-2x"></i>
                            </a>
                            <a href="#" class="text-info">
                                <i class="icon-twitter fa-2x"></i>
                            </a>
                            <a href="#" class="text-primary">
                                <i class="icon-linkedin fa-2x"></i>
                            </a>
                            <a href="#" class="text-success">
                                <i class="icon-whatsapp fa-2x"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="site-section ftco-subscribe-1" style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h2>Des questions sur cette filière ?</h2>
                <p>Notre équipe d'orientation est là pour vous aider à faire le bon choix.</p>
            </div>
            <div class="col-lg-5">
                <a href="{{ path('app_contact') }}" class="btn btn-primary rounded py-3 px-4 btn-block">Contacter un conseiller</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}