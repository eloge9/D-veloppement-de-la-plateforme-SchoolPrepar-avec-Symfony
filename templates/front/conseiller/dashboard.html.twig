{% extends 'front/base.html.twig' %}

{% block title %}Dashboard Conseiller - SchoolPrepar{% endblock %}

{% block content %}
<div class="site-section ftco-subscribe-1 site-blocks-cover pb-4"
    style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <h2 class="mb-0">Espace Conseiller</h2>
                <p>Bienvenue {{ user.nom }} dans votre tableau de bord</p>
            </div>
        </div>
    </div>
</div>

<div class="custom-breadcrumns border-bottom">
    <div class="container">
        <a href="{{ path('app_home') }}">Home</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <span class="current">Dashboard Conseiller</span>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title font-weight-bold">Menu</h5>
                        <div class="list-group list-group-flush">
                            <a href="#" class="list-group-item list-group-item-action active">
                                <i class="fas fa-tachometer-alt mr-2"></i>Dashboard
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-users mr-2"></i>Étudiants
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-comments mr-2"></i>Consultations
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-calendar-check mr-2"></i>Rendez-vous
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-graduation-cap mr-2"></i>Orientation
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Profile Card -->
                <div class="card shadow">
                    <div class="card-body text-center">
                        <img src="{{ asset('assets/images/person_2.jpg') }}" class="rounded-circle mb-3" alt="Profile" width="80">
                        <h6 class="card-title">{{ user.nom }}</h6>
                        <p class="text-muted small">{{ user.email }}</p>
                        <span class="badge badge-success">Conseiller</span>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <!-- Statistics Cards -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-primary font-weight-bold">45</h3>
                                <p class="text-muted">Étudiants suivis</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-success font-weight-bold">28</h3>
                                <p class="text-muted">Consultations</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-info font-weight-bold">12</h3>
                                <p class="text-muted">Rendez-vous</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-warning font-weight-bold">4.8</h3>
                                <p class="text-muted">Note moyenne</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Actions Rapides</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="card border-primary h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-user-plus fa-3x text-primary mb-3"></i>
                                        <h6>Nouveau suivi</h6>
                                        <p class="text-muted small">Ajouter un étudiant</p>
                                        <button class="btn btn-primary btn-sm">Ajouter</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="card border-success h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-calendar-plus fa-3x text-success mb-3"></i>
                                        <h6>Prendre RDV</h6>
                                        <p class="text-muted small">Planifier consultation</p>
                                        <button class="btn btn-success btn-sm">Planifier</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="card border-info h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-file-medical fa-3x text-info mb-3"></i>
                                        <h6>Rapport</h6>
                                        <p class="text-muted small">Générer rapport</p>
                                        <button class="btn btn-info btn-sm">Générer</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="card shadow">
                    <div class="card-header">
                        <h5 class="mb-0">Activité Récente</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">Consultation terminée</h6>
                                        <p class="text-muted small mb-0">Session d'orientation avec Marie Martin</p>
                                    </div>
                                    <small class="text-muted">Il y a 1 heure</small>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">Nouveau rendez-vous</h6>
                                        <p class="text-muted small mb-0">RDV prévu avec Pierre Durand</p>
                                    </div>
                                    <small class="text-muted">Il y a 3 heures</small>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">Rapport envoyé</h6>
                                        <p class="text-muted small mb-0">Bilan semestriel complété</p>
                                    </div>
                                    <small class="text-muted">Hier</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
