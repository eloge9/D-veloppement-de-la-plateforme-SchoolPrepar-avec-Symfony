{% extends 'front/base.html.twig' %}

{% block title %}Administration - SchoolPrepar{% endblock %}

{% block content %}
<div class="site-section ftco-subscribe-1 site-blocks-cover pb-4" style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <h2 class="mb-0">Administration</h2>
                <p>Bienvenue {{ user.nom }}, voici votre tableau de bord administrateur</p>
            </div>
        </div>
    </div>
</div>

<div class="custom-breadcrumns border-bottom">
    <div class="container">
        <a href="{{ path('app_home') }}">Home</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <span class="current">Administration</span>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-3">
                <div class="card shadow">
                    <div class="card-body">
                        <h5 class="card-title">Menu Admin</h5>
                        <div class="list-group">
                            <a href="#" class="list-group-item list-group-item-action active">
                                <i class="icon-home mr-2"></i>Tableau de bord
                            </a>
                            <a href="/admin/utilisateur" class="list-group-item list-group-item-action">
                                <i class="icon-users mr-2"></i>Gestion utilisateurs
                            </a>
                            <a href="/admin/etablissement" class="list-group-item list-group-item-action">
                                <i class="icon-building mr-2"></i>Établissements
                            </a>
                            <a href="/admin/filiere" class="list-group-item list-group-item-action">
                                <i class="icon-graduation-cap mr-2"></i>Filières
                            </a>
                            <a href="/admin/evenement" class="list-group-item list-group-item-action">
                                <i class="icon-calendar mr-2"></i>Événements
                            </a>
                            <a href="/admin/rendezvous" class="list-group-item list-group-item-action">
                                <i class="icon-clock mr-2"></i>Rendez-vous
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="icon-bar-chart mr-2"></i>Statistiques
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="icon-settings mr-2"></i>Paramètres
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-9">
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body">
                                <h5 class="card-title">Utilisateurs</h5>
                                <p class="card-text display-4">156</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body">
                                <h5 class="card-title">Établissements</h5>
                                <p class="card-text display-4">42</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-info text-white">
                            <div class="card-body">
                                <h5 class="card-title">Filières</h5>
                                <p class="card-text display-4">89</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning text-white">
                            <div class="card-body">
                                <h5 class="card-title">Événements</h5>
                                <p class="card-text display-4">12</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Panneau d'Administration SchoolPrepar</h5>
                        <p class="card-text">
                            Gérez l'ensemble de la plateforme SchoolPrepar depuis ce tableau de bord administrateur.
                        </p>
                        <div class="mt-4">
                            <a href="/admin/utilisateur" class="btn btn-primary mr-2">
                                <i class="icon-users mr-2"></i>Gérer les utilisateurs
                            </a>
                            <a href="/admin/etablissement" class="btn btn-outline-primary">
                                <i class="icon-building mr-2"></i>Gérer les établissements
                            </a>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="card shadow">
                            <div class="card-body">
                                <h5 class="card-title">Activités récentes</h5>
                                <div class="list-group">
                                    <div class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1">Nouvel utilisateur inscrit</h6>
                                            <small>Il y a 1 heure</small>
                                        </div>
                                        <p class="mb-1">Jean Dupont s'est inscrit en tant qu'étudiant.</p>
                                    </div>
                                    <div class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1">Nouvel établissement ajouté</h6>
                                            <small>Il y a 3 heures</small>
                                        </div>
                                        <p class="mb-1">Université Lyon 1 a été ajoutée à la plateforme.</p>
                                    </div>
                                    <div class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1">Filière mise à jour</h6>
                                            <small>Hier</small>
                                        </div>
                                        <p class="mb-1">Les informations de la filière Informatique ont été mises à jour.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card shadow">
                            <div class="card-body">
                                <h5 class="card-title">Statistiques rapides</h5>
                                <div class="row">
                                    <div class="col-6 text-center">
                                        <h4>85%</h4>
                                        <small class="text-muted">Taux de satisfaction</small>
                                    </div>
                                    <div class="col-6 text-center">
                                        <h4>1.2k</h4>
                                        <small class="text-muted">Visites ce mois</small>
                                    </div>
                                    <div class="col-6 text-center mt-3">
                                        <h4>234</h4>
                                        <small class="text-muted">Inscriptions cette semaine</small>
                                    </div>
                                    <div class="col-6 text-center mt-3">
                                        <h4>98%</h4>
                                        <small class="text-muted">Uptime serveur</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
