{% extends 'base.html.twig' %}

{% block title %}Accueil — SchoolPrepar{% endblock %}

{% block body %}


<section class="bg-blue-700 text-white py-20 px-6 text-center">
    <p class="text-xs tracking-widest text-blue-200 uppercase mb-2">Orientation scolaire</p>
    <h1 class="text-4xl font-semibold mb-4">Bienvenue sur SchoolPrepar</h1>
    <p class="text-lg text-blue-100 max-w-xl mx-auto mb-8">
        Trouve ta filière, connecte-toi à un conseiller, construis ton avenir.
    </p>
    <a href="{{ path('course.index') }}" class="btn bg-white text-blue-700 border-none hover:bg-blue-50 font-semibold">
        Explorer les filières →
    </a>
</section>


<section class="bg-blue-800 py-6 px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto text-center text-white">
        {% for stat in [
            {value: '200+', label: 'Filières'},
            {value: '150+', label: 'Établissements'},
            {value: '80+',  label: 'Conseillers'},
            {value: '5 000+', label: 'Élèves aidés'},
        ] %}
            <div class="bg-blue-900 rounded-xl p-5">
                <p class="text-2xl font-semibold">{{ stat.value }}</p>
                <p class="text-sm text-blue-300 mt-1">{{ stat.label }}</p>
            </div>
        {% endfor %}
    </div>
</section>


<section class="py-16 px-6 max-w-5xl mx-auto">
    <h2 class="text-2xl font-semibold text-gray-800 mb-8">Filières disponibles</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        {% set filieres = [
            {name: 'Médecine et Santé',           badge: 'Santé',    badge_class: 'badge-info',    debouches: 'Médecin · Infirmier · Pharmacien'},
            {name: 'Informatique',                badge: 'Tech',     badge_class: 'badge-success', debouches: 'Développeur · Data Analyst · DevOps'},
            {name: 'Droit et Sciences Po',        badge: 'Droit',    badge_class: 'badge-warning', debouches: 'Avocat · Magistrat · Diplomate'},
            {name: 'Commerce et Gestion',         badge: 'Commerce', badge_class: 'badge-primary', debouches: 'Manager · Comptable · RH'},
            {name: 'Lettres et Sciences Humaines',badge: 'Lettres',  badge_class: 'badge-secondary',debouches: 'Enseignant · Journaliste · Sociologue'},
            {name: 'Ingénierie et BTP',           badge: 'BTP',      badge_class: 'badge-accent',  debouches: 'Ingénieur Civil · Architecte'},
        ] %}

        {% for f in filieres %}
        <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow">
            <div class="card-body p-5">
                <div class="badge {{ f.badge_class }} badge-sm mb-3">{{ f.badge }}</div>
                <h3 class="card-title text-base font-semibold">{{ f.name }}</h3>
                <p class="text-sm text-gray-500">{{ f.debouches }}</p>
            </div>
        </div>
        {% endfor %}

    </div>
    <div class="text-center mt-10">
        <a href="{{ path('course.index') }}" class="btn btn-primary">
            Explorer toutes les filières →
        </a>
    </div>
</section>


<section class="bg-base-200 py-16 px-6">
    <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-semibold text-gray-800 mb-8">Nos services</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

            {% set services = [
                {title: 'Quiz d\'orientation',        desc: 'Découvre la filière faite pour toi.',        icon: '?'},
                {title: 'Mentorat personnalisé',      desc: 'Échange avec anciens élèves et pros.',       icon: '👥'},
                {title: 'Événements et Webinaires',   desc: 'Salons et conférences en ligne.',            icon: '📅'},
                {title: 'Recommandations',            desc: 'Parcours adapté à ton profil.',              icon: '★'},
            ] %}

            {% for s in services %}
                <div class="card bg-base-100 border border-base-200 shadow-sm">
                    <div class="card-body p-5">
                        <div class="text-2xl mb-2">{{ s.icon }}</div>
                        <h3 class="font-semibold text-base">{{ s.title }}</h3>
                        <p class="text-sm text-gray-500">{{ s.desc }}</p>
                    </div>
                </div>
            {% endfor %}

        </div>
    </div>
</section>

{% endblock %}
