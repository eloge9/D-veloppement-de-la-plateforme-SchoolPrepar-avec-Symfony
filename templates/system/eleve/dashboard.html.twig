{% extends 'system/base.html.twig' %}

{% block title %}Dashboard Élève - SchoolPrepar{% endblock %}

{% block content %}
<div class="site-section ftco-subscribe-1 site-blocks-cover pb-4"
    style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <h2 class="mb-0">Espace Élève</h2>
                <p>Bienvenue {{ user.nom }} dans votre tableau de bord</p>
            </div>
        </div>
    </div>
</div>

<div class="custom-breadcrumns border-bottom">
    <div class="container">
        <a href="{{ path('app_vitrine_home') }}">Home</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <span class="current">Dashboard Élève</span>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title font-weight-bold">Menu</h5>
                        <div class="list-group list-group-flush">
                            <a href="#" class="list-group-item list-group-item-action active">
                                <i class="fas fa-tachometer-alt mr-2"></i>Dashboard
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-book mr-2"></i>Mes Cours
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-tasks mr-2"></i>Devoirs
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-chart-line mr-2"></i>Mes Notes
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-user-graduate mr-2"></i>Mon Profil
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Profile Card -->
                <div class="card shadow">
                    <div class="card-body text-center">
                        <img src="{{ asset('assets/images/person_3.jpg') }}" class="rounded-circle mb-3" alt="Profile"
                            width="80">
                        <h6 class="card-title">{{ user.nom }}</h6>
                        <p class="text-muted small">{{ user.email }}</p>
                        <span class="badge badge-info">Élève</span>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <!-- Statistics Cards -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-primary font-weight-bold">8</h3>
                                <p class="text-muted">Cours actifs</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-success font-weight-bold">15.2</h3>
                                <p class="text-muted">Moyenne</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-info font-weight-bold">3</h3>
                                <p class="text-muted">Devoirs en cours</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow text-center">
                            <div class="card-body">
                                <h3 class="text-warning font-weight-bold">92%</h3>
                                <p class="text-muted">Assiduité</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Actions Rapides</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="card border-primary h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-book-open fa-3x text-primary mb-3"></i>
                                        <h6>Voir mes cours</h6>
                                        <p class="text-muted small">Accéder au contenu</p>
                                        <button class="btn btn-primary btn-sm">Voir</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="card border-success h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-edit fa-3x text-success mb-3"></i>
                                        <h6>Faire un devoir</h6>
                                        <p class="text-muted small">Soumettre travail</p>
                                        <button class="btn btn-success btn-sm">Commencer</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="card border-warning h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-calendar fa-3x text-warning mb-3"></i>
                                        <h6>Emploi du temps</h6>
                                        <p class="text-muted small">Voir planning</p>
                                        <button class="btn btn-warning btn-sm">Voir</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="card shadow">
                    <div class="card-header">
                        <h5 class="mb-0">Activité Récente</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">Devoir soumis</h6>
                                        <p class="text-muted small mb-0">Mathématiques - Exercice 3.2</p>
                                    </div>
                                    <small class="text-muted">Il y a 2 heures</small>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">Note obtenue</h6>
                                        <p class="text-muted small mb-0">Physique - 17/20</p>
                                    </div>
                                    <small class="text-muted">Hier</small>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">Nouveau cours</h6>
                                        <p class="text-muted small mb-0">Chimie - Chapitre 4 disponible</p>
                                    </div>
                                    <small class="text-muted">Il y a 2 jours</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}