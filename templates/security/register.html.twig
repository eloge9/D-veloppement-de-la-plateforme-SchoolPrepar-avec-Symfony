{% extends 'front/base.html.twig' %}

{% block title %}Inscription - SchoolPrepar{% endblock %}

{% block content %}
<div class="site-section ftco-subscribe-1 site-blocks-cover pb-4"
    style="background-image: url('{{ asset('assets/images/bg_1.jpg') }}')">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <h2 class="mb-0">Inscription</h2>
                <p>Rejoignez la communauté SchoolPrepar</p>
            </div>
        </div>
    </div>
</div>

<div class="custom-breadcrumns border-bottom">
    <div class="container">
        <a href="{{ path('app_vitrine_home') }}">Home</a>
        <span class="mx-3 icon-keyboard_arrow_right"></span>
        <span class="current">Inscription</span>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card shadow">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="font-weight-bold">Créer votre compte</h3>
                            <p class="text-muted">Rejoignez SchoolPrepar et accédez à nos services</p>
                        </div>

                        {{ form_start(registrationForm, {'attr': {'class': 'needs-validation', 'novalidate':
                        'novalidate'}}) }}

                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.nom, 'Nom complet', {'label_attr': {'class': 'form-label'}})
                            }}
                            {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.nom) }}
                        </div>

                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.email, 'Adresse email', {'label_attr': {'class':
                            'form-label'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.mot_de_passe.first, 'Mot de passe', {'label_attr': {'class':
                            'form-label'}}) }}
                            {{ form_widget(registrationForm.mot_de_passe.first, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.mot_de_passe.first) }}
                        </div>

                        <div class="form-group mb-4">
                            {{ form_label(registrationForm.mot_de_passe.second, 'Confirmer le mot de passe',
                            {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.mot_de_passe.second, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.mot_de_passe.second) }}
                        </div>

                        <div class="form-group mb-4">
                            {{ form_label(registrationForm.role, 'Je suis un :', {'label_attr': {'class':
                            'form-label'}}) }}
                            {{ form_widget(registrationForm.role, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.role) }}
                        </div>

                        {{ form_widget(registrationForm._token) }}

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                S'inscrire
                            </button>
                        </div>

                        {{ form_end(registrationForm) }}

                        <div class="text-center mt-4">
                            <p class="mb-0">Déjà un compte ?</p>
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
                                Se connecter
                            </a>
                        </div>

                        <div class="alert alert-info mt-4">
                            <small class="text-muted">
                                En vous inscrivant, vous acceptez nos conditions d'utilisation.
                                Choisissez votre rôle : Élève, Conseiller/Mentor ou Établissement.
                                Les comptes administrateurs sont créés uniquement par les administrateurs existants.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}